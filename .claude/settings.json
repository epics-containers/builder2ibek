{
  "permissions": {
    "allow": [
      "Edit(/workspaces/**)",
      "Write(/workspaces/**)",
      "Read(/workspaces/**)",
      "Read(/dls_sw/**)",
      "Read(//dls_sw/**)",
      "Edit(/epics/**)",
      "Read(/epics/**)",
      "Write(/epics/**)",
      "Bash(*)"
    ],
    "additionalDirectories": [
      "/workspaces/builder2ibek/.claude/skills",
      "/dls_sw/work",
      "/dls_sw/prod",
      "/epics"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -z \"$REMOTE_CONTAINERS\" ]; then echo 'BLOCKED: This project requires the devcontainer. Please reopen in the devcontainer before using Claude Code.'; exit 2; fi"
          }
        ]
      }
    ]
  }
}
